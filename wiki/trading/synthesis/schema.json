{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily State — Strategy Synthesizer Output",
  "description": "Unified market state synthesized from all modules, theses, and market data. Generated by synthesis/synthesizer.py. Read by engine.py and delivery.py.",
  "type": "object",
  "required": ["meta", "market_regime", "composite_confluence_score", "primary_risk_factor", "divergences", "thesis_recommendations", "data_gaps"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at", "synthesizer_version", "modules_loaded", "theses_active", "data_freshness"],
      "properties": {
        "generated_at": {"type": "string", "description": "ISO 8601 timestamp in IST"},
        "synthesizer_version": {"type": "string", "default": "v0.1"},
        "modules_loaded": {"type": "integer", "minimum": 0, "maximum": 14},
        "theses_active": {"type": "integer", "minimum": 0, "maximum": 3},
        "data_freshness": {"type": "string", "enum": ["live", "stale", "fallback"]},
        "fallback_reason": {"type": "string", "description": "Only present when data_freshness is 'fallback'"}
      }
    },
    "market_regime": {
      "type": "object",
      "required": ["primary", "confidence"],
      "properties": {
        "primary": {"type": "string", "enum": ["RISK_ON", "CAUTIOUS", "RISK_OFF", "PANIC", "STAGFLATION", "GOLDILOCKS", "UNKNOWN"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "components": {
          "type": "object",
          "properties": {
            "trend": {"type": "string"},
            "volatility": {"type": "string"},
            "macro": {"type": "string"},
            "sentiment": {"type": "string"},
            "session": {"type": "string"}
          }
        }
      }
    },
    "composite_confluence_score": {
      "type": "object",
      "required": ["value", "range", "interpretation"],
      "properties": {
        "value": {"type": "integer", "minimum": -5, "maximum": 5},
        "range": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
        "interpretation": {"type": "string"},
        "thesis_scores": {
          "type": "object",
          "properties": {
            "commodity": {"type": "integer", "minimum": -2, "maximum": 2},
            "ai": {"type": "integer", "minimum": -2, "maximum": 2},
            "crypto": {"type": "integer", "minimum": -2, "maximum": 2}
          }
        }
      }
    },
    "primary_risk_factor": {
      "type": "object",
      "required": ["factor", "severity", "description"],
      "properties": {
        "factor": {"type": "string"},
        "severity": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
        "description": {"type": "string"},
        "affected_theses": {"type": "array", "items": {"type": "string"}}
      }
    },
    "divergences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "detail"],
        "properties": {
          "type": {"type": "string"},
          "severity": {"type": "string", "enum": ["INFO", "WATCH", "WARNING", "ALERT"]},
          "detail": {"type": "string"},
          "modules_involved": {"type": "array", "items": {"type": "string"}},
          "thesis_impact": {"type": "string"},
          "recommended_action": {"type": "string"}
        }
      }
    },
    "thesis_recommendations": {
      "type": "object",
      "required": ["commodity", "ai", "crypto"],
      "properties": {
        "commodity": {
          "type": "object",
          "required": ["bias", "action", "size_adjustment"],
          "properties": {
            "bias": {"type": "string", "enum": ["BULLISH", "SLIGHTLY_BULLISH", "NEUTRAL", "SLIGHTLY_BEARISH", "BEARISH"]},
            "action": {"type": "string"},
            "next_signal_watch": {"type": "string"},
            "size_adjustment": {"type": "number", "minimum": 0, "maximum": 1},
            "active_positions": {"type": "array", "items": {"type": "object"}},
            "notes": {"type": "string"}
          }
        },
        "ai": {
          "type": "object",
          "required": ["bias", "action", "size_adjustment"],
          "properties": {
            "bias": {"type": "string", "enum": ["BULLISH", "SLIGHTLY_BULLISH", "NEUTRAL", "SLIGHTLY_BEARISH", "BEARISH"]},
            "action": {"type": "string"},
            "next_signal_watch": {"type": "string"},
            "size_adjustment": {"type": "number", "minimum": 0, "maximum": 1},
            "notes": {"type": "string"}
          }
        },
        "crypto": {
          "type": "object",
          "required": ["bias", "action", "size_adjustment"],
          "properties": {
            "bias": {"type": "string", "enum": ["BULLISH", "SLIGHTLY_BULLISH", "NEUTRAL", "SLIGHTLY_BEARISH", "BEARISH"]},
            "action": {"type": "string"},
            "next_signal_watch": {"type": "string"},
            "size_adjustment": {"type": "number", "minimum": 0, "maximum": 1},
            "notes": {"type": "string"}
          }
        }
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "gap", "impact"],
        "properties": {
          "module": {"type": "string"},
          "gap": {"type": "string"},
          "impact": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
          "fix": {"type": "string"}
        }
      }
    }
  }
}
